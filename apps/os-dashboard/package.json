{
  "name": "axionax-os-dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3030",
    "build": "next build",
    "start": "next start -p 3030",
    "serve:lh": "next start -p 3031",
    "lighthouse:run": "lighthouse http://127.0.0.1:3031/ --only-categories=performance,accessibility,best-practices,seo --preset=desktop --quiet --chrome-flags=\"--headless=new --no-sandbox\" --output=json --output=html --output-path=./lighthouse-results/lhr",
    "lighthouse:report": "pnpm build && start-server-and-test serve:lh http-get://127.0.0.1:3031 lighthouse:run",
    "lint": "next lint",
    "icons:resize": "node scripts/resize-icons.mjs"
  },
  "dependencies": {
    "@axionax/sdk": "workspace:*",
    "clsx": "^2.1.1",
    "lucide-react": "^0.438.0",
    "next": "14.2.5",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "tailwind-merge": "^2.5.2"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.4.20",
    "lighthouse": "^13.2.0",
    "postcss": "^8.4.45",
    "sharp": "^0.33.5",
    "start-server-and-test": "^3.0.2",
    "tailwindcss": "^3.4.10",
    "typescript": "^5.5.4"
  }
}
