# Blockscout 6.4.0 — Axionax Testnet
# Generated from explorer.env.example
# ⚠️  Replace SECRET_KEY_BASE and DATABASE_URL password before deploying to production.

# --- Chain RPC (Docker service name) ---
ETHEREUM_JSONRPC_HTTP_URL=http://rpc:8545
ETHEREUM_JSONRPC_TRACE_URL=http://rpc:8545
ETHEREUM_JSONRPC_VARIANT=geth
ETHEREUM_JSONRPC_WS_URL=ws://rpc:8546

# --- Database (postgres service in docker-compose) ---
DATABASE_URL=postgresql://blockscout:blockscout_dev@postgres:5432/blockscout

# --- Phoenix secret (generate with: openssl rand -base64 48) ---
SECRET_KEY_BASE=axionax_testnet_CHANGE_ME_openssl_rand_base64_48_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Redis cache ---
REDIS_URL=redis://redis:6379

# --- Chain identity ---
CHAIN_ID=86137
COIN=AXX
COIN_NAME=Axionax
NETWORK=Axionax
SUBNETWORK=Testnet

# --- Blockscout server ---
PORT=4000
DISABLE_WEBAPP=false
API_V2_ENABLED=true

# --- Indexer ---
INDEXER_DISABLE_INTERNAL_TRANSACTIONS_FETCHER=false
INDEXER_MEMORY_LIMIT=1073741824

# --- Block time / finality ---
AVERAGE_BLOCK_PERIOD=5000
TOKEN_DECIMALS=18

# --- Optional features ---
SHOW_PRICE_CHART=false
SHOW_TXS_CHART=true
DISABLE_EXCHANGE_RATES=true
DISABLE_KNOWN_TOKENS=false
ENABLE_1559_SUPPORT=false
TXS_STATS_ENABLED=true
SHOW_ADDRESS_MARKETCAP_PERCENTAGE=false

# --- Logging ---
ECTO_USE_SSL=false
POOL_SIZE=10
POOL_SIZE_API=2
