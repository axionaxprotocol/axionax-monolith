# Copy to faucet.env (never commit faucet.env):
#   cp faucet.env.example faucet.env
# Then set FAUCET_PRIVATE_KEY to a 32-byte Ed25519 seed (64 hex chars, optional 0x).
# The derived faucet address MUST hold a balance on chain (genesis allocation).

# Required — Ed25519 signing key (32 bytes = 64 hex)
FAUCET_PRIVATE_KEY=

# JSON-RPC for axionax-node (inside Compose use service name + internal port)
RPC_URL=http://rpc:8545

CHAIN_ID=86137

# Must match docker-compose ports "8080:8080"
PORT=8080

# Amount per request in whole AXX (app multiplies by 10^18)
FAUCET_AMOUNT=100

# Cooldown between requests per IP / per address (minutes → seconds internally)
RATE_LIMIT_MINUTES=60

# Optional: comma-separated origins for CORS (unset = permissive)
# CORS_ORIGINS=https://app.example.com
