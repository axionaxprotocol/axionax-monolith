# Axionax DeAI Worker — environment overrides
# Copy to .env and set values. Optional: overrides [network] in worker_config.toml

# Single RPC URL (used as sole bootnode when set)
# AXIONAX_RPC_URL=http://127.0.0.1:8545

# Or comma-separated list of RPC URLs (overrides config [network] bootnodes)
# AXIONAX_BOOTNODES=http://217.76.61.116:8545,http://46.250.244.4:8545

# Chain ID (default from config: 86137)
# AXIONAX_CHAIN_ID=86137

# Runtime mode used by sandbox hardening ("production" enables strict mode)
# AXIONAX_ENV=production

# Wallet key file path (default: worker_key.json in same dir as config)
# AXIONAX_WALLET_PATH=./worker_key.json

# Wallet password (optional; if set, no interactive prompt — production: use secrets manager)
# WORKER_KEY_PASSWORD=your_secure_password

# Raw private key (optional; overrides file — use only in secure env, never commit)
# WORKER_PRIVATE_KEY=0x...

# Marketplace contract address (required for LIVE mode, otherwise worker runs in MOCK mode)
# AXIONAX_MARKETPLACE_ADDRESS=0x0000000000000000000000000000000000000000

# Optional ABI path override for marketplace contract
# AXIONAX_ABI_PATH=./job_marketplace.json
