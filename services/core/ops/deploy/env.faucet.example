# Testnet Faucet env for deployment co-located with RPC node.
# Copy to .env.faucet, set the private key, DO NOT COMMIT the real file.
#
# Deterministic testnet key (matches ed25519-derived faucet address
# 0x9dd7e28ccd04cfb6547adc7be2a8cf2beb434a1c which has 30B AXX allocated in genesis.json).
# The chain signs txs with ed25519 natively, so the same 32-byte key yields a
# DIFFERENT address than ETH-style (secp256k1) derivation would.
#   python3 -c "import hashlib; print('0x'+hashlib.sha256(b'axionax_faucet_mainnet_q2_2026').hexdigest())"

FAUCET_PRIVATE_KEY=
