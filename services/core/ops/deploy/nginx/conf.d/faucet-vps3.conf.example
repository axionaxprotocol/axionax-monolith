# VPS3: Faucet when running as standalone container (port 3002 on host).
# Copy to /etc/nginx/conf.d/ or include in your nginx config.
# Then: proxy_pass http://127.0.0.1:3002 (not http://faucet:3002).

limit_req_zone $binary_remote_addr zone=faucet_limit:10m rate=1r/s;

server {
    listen 80;
    server_name faucet.axionax.org;
    location /.well-known/acme-challenge/ { root /var/www/certbot; }
    location / { return 301 https://$server_name$request_uri; }
}

server {
    listen 443 ssl http2;
    server_name faucet.axionax.org;
    ssl_certificate /etc/letsencrypt/live/faucet.axionax.org/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/faucet.axionax.org/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;

    location / {
        proxy_pass http://127.0.0.1:3002;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        limit_req zone=faucet_limit burst=5 nodelay;
    }
}
