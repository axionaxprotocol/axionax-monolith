# Environment variables for VPS deployment
# Copy this to .env and fill in your values

# Database
DB_PASSWORD=your_secure_postgres_password_here

# Redis
REDIS_PASSWORD=your_secure_redis_password_here

# Faucet
FAUCET_PRIVATE_KEY=your_faucet_private_key_here

# Grafana
GRAFANA_PASSWORD=your_secure_grafana_admin_password_here

# VPS Configuration
VPS_IP=your_vps_ip_address_here
DOMAIN=axionax.org

# P2P Configuration (for simple node deployment)
AXIONAX_PUBLIC_IP=your_public_ip_here
AXIONAX_BOOTSTRAP_NODES=/ip4/<bootstrap_ip>/tcp/30303/p2p/<bootstrap_peer_id>
