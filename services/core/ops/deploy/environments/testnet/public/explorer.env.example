# Copy to explorer.env (gitignored):
#   cp explorer.env.example explorer.env
#
# Blockscout needs many variables; see https://docs.blockscout.com/setup/env-variables
# Critical for Axionax public testnet Compose: index the SAME node that produces blocks.

# --- Chain RPC (Docker network: use service name validator) ---
ETHEREUM_JSONRPC_HTTP_URL=http://validator:8545
ETHEREUM_JSONRPC_TRACE_URL=http://validator:8545
ETHEREUM_JSONRPC_VARIANT=geth

# --- Required by Blockscout (set real values; do not commit secrets) ---
# DATABASE_URL=postgresql://blockscout:PASSWORD@postgres:5432/blockscout
# SECRET_KEY_BASE=  # long random string
# REDIS_URL=redis://redis:6379
